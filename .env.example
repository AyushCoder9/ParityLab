APP_ENV=development
WEB_ORIGIN=http://127.0.0.1:3000
API_ORIGIN=http://localhost:8080
NEXT_PUBLIC_PARITYLAB_API_URL=http://127.0.0.1:8080
DATABASE_URL=postgres://paritylab:paritylab@localhost:5432/paritylab?sslmode=disable
# Stripe Sandbox credentials only. ParityLab rejects live-mode keys and events.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ENDPOINT_TOKEN=demo
# Generate unique high-entropy values locally; never commit the populated file.
PARITYLAB_ENCRYPTION_KEY=
AUTH_SECRET=
PARITYLAB_SIGNING_SECRET=
